@page "/categorias/editar/{id}"
@inherits EditCategoryPage

<MudText Typo="Typo.h3">Editar categoria</MudText>
@if (IsBusy)
{
    <MudPaper Class="pa-8 mt-4">
        <MudSkeleton Height="55px"></MudSkeleton>
        <MudSkeleton Height="110px"></MudSkeleton>
        <MudSkeleton Height="55px"></MudSkeleton>
        <MudSkeleton Height="110px"></MudSkeleton>
        <MudSkeleton Height="55px"></MudSkeleton>
        <MudSkeleton Height="110px"></MudSkeleton>
        <MudSkeleton Height="55px"></MudSkeleton>
    </MudPaper>
}
else
{
    <MudPaper Class="pa-8 mt-4">
        <EditForm Model="@Request" OnValidSubmit="OnValidSubmitAsync">
            <DataAnnotationsValidator/>
            <MudTextField 
                Label="Título"
                HelperText="Campo obrigatório"
                @bind-Value="Request.Title"
                For="@(() => Request.Title) "/>
        
            <MudTextField 
                Label="Descrição"
                Lines="5"
                HelperText="Campo obrigatório"
                @bind-Value="Request.Description"
                For="@(() => Request.Description) "/>
        
            <div class="d-flex mt-8">
                @if (IsBusy)
                {
                    <MudProgressCircular Color="Color.Info" Indeterminate="true"/>
                }
                else
                {
                    <MudButton
                        ButtonType="ButtonType.Submit"
                        Variant="Variant.Filled"
                        Color="Color.Primary">
                        Salvar
                    </MudButton>
                }
            </div>
        
        </EditForm>
    </MudPaper>
}